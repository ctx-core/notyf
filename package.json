{
	"name": "@ctx-core/notyf",
	"version": "2.1.222",
	"type": "module",
	"files": [
		"*.d.ts",
		"*.js",
		"*.json",
		"./_types",
		"./active_notyf_o_a",
		"./notyf",
		"./notyf_banner_error_map",
		"./notyf_config",
		"./notyf_error",
		"./notyf_message",
		"./notyf_options_",
		"./notyf_success",
		"./notyf_warn"
	],
	"main": "./index.js",
	"module": "./index.js",
	"types": "./index.d.ts",
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "bun run clean && bun run build && bun run test && publint && attw --pack --ignore-rules cjs-resolves-to-esm",
		"test": "bun run test:types && bun run test:unit",
		"test:types": "tsc --noEmit",
		"test:unit": "tsx node_modules/uvu/bin.js . '\\.test\\.(ts|js)$'",
		"disable:test:unit:coverage": "c8 bun run test:unit"
	},
	"dependencies": {
		"ctx-core": "*",
		"notyf": "^3.10.0"
	},
	"devDependencies": {
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"noUpdate": []
}
